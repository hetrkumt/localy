# ==========================================
# 🤖 1. AI Agents & IDE (Aider, Cursor)
# ==========================================
.aider*
.env
.env.*
.vscode/
.idea/

# ==========================================
# ☁️ 2. Terraform Core (State, Plugins)
# ==========================================
# 로컬 플러그인 캐시 무시
**/.terraform/*

# 민감 정보 원장 (State) 무시 - 절대 Git에 올라가면 안됨
**/*.tfstate
**/*.tfstate.*


# 테라폼 실행 계획 (Plan) 무시 - 인프라 구조/비밀번호 평문 노출 방지
**/*.tfplan
 **/tfplan

# 에러 크래시 로그
crash.log
crash.*

# ==========================================
# 🔑 3. Terraform Variables & Overrides
# ==========================================
# 실제 비밀번호 및 환경 변수 파일 무시
**/*.tfvars
**/*.tfvars.json

# Override 파일 무시
**/*_override.tf
**/*_override.tf.json

# ==========================================
# 🍏 4. OS Files
# ==========================================
.DS_Store
Thumbs.db

# Accidental git log / pager artifacts (e.g. "ion: v1")
ion:*

# ==========================================
# 🛠️ 5. Local Scripts & Utilities
# ==========================================
# 로컬 스크립트 폴더 전체 무시
local_scripts/

# Lambda placeholder zip (terraform archive_file 생성물)
**/.artifacts/
